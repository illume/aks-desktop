+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+import { describe, expect, it } from 'vitest';
+import { sanitizeException, sanitizeUrl } from './analytics';
+
+describe('sanitizeUrl', () => {
+  it('replaces cluster name after /c/', () => {
+    expect(sanitizeUrl('/c/my-cluster/pods')).toBe('/c/{id}/pods');
+  });
+
+  it('replaces namespace and resource name', () => {
+    expect(sanitizeUrl('/c/my-cluster/pods/production/nginx-abc123')).toBe(
+      '/c/{id}/pods/{id}/{id}'
+    );
+  });
+
+  it('replaces secret namespace and name', () => {
+    expect(sanitizeUrl('/secrets/kube-system/my-secret')).toBe('/secrets/{id}/{id}');
+  });
+
+  it('keeps known resource types intact', () => {
+    expect(sanitizeUrl('/deployments')).toBe('/deployments');
+    expect(sanitizeUrl('/services')).toBe('/services');
+    expect(sanitizeUrl('/configmaps')).toBe('/configmaps');
+  });
+
+  it('handles full URLs and strips query params', () => {
+    expect(sanitizeUrl('https://localhost:4466/c/cluster1/nodes')).toBe('/c/{id}/nodes');
+  });
+
+  it('strips query parameters that may contain sensitive data', () => {
+    expect(sanitizeUrl('/pods?namespace=secret-ns&token=abc')).toBe('/pods');
+  });
+
+  it('strips hash fragments', () => {
+    expect(sanitizeUrl('/pods#some-anchor')).toBe('/pods');
+  });
+
+  it('handles empty path', () => {
+    expect(sanitizeUrl('/')).toBe('/');
+  });
+
+  it('returns placeholder for malformed input', () => {
+    // Test that it at least doesn't throw and returns something safe
+    const result = sanitizeUrl('');
+    expect(result).toBe('/');
+  });
+
+  it('handles AKS Desktop plugin routes', () => {
+    expect(sanitizeUrl('/azure/login')).toBe('/azure/login');
+    expect(sanitizeUrl('/projects/create-aks-project')).toBe('/projects/create-aks-project');
+    expect(sanitizeUrl('/add-cluster-aks')).toBe('/add-cluster-aks');
+  });
+
+  it('replaces unknown path segments with {id}', () => {
+    expect(sanitizeUrl('/c/prod-cluster/customresources/my-crd-group/default/my-resource')).toBe(
+      '/c/{id}/customresources/{id}/{id}/{id}'
+    );
+  });
+
+  it('is case-insensitive for known segments', () => {
+    expect(sanitizeUrl('/Pods')).toBe('/Pods');
+    expect(sanitizeUrl('/DEPLOYMENTS')).toBe('/DEPLOYMENTS');
+  });
+
+  it('never leaks cluster names', () => {
+    const urls = [
+      '/c/production-cluster/pods',
+      '/c/my-company-aks-eastus/deployments/kube-system/coredns',
+      'https://app.example.com/c/staging-us-west-2/secrets/default/db-credentials',
+    ];
+    for (const url of urls) {
+      const sanitized = sanitizeUrl(url);
+      expect(sanitized).not.toContain('production-cluster');
+      expect(sanitized).not.toContain('my-company-aks-eastus');
+      expect(sanitized).not.toContain('staging-us-west-2');
+      expect(sanitized).not.toContain('kube-system');
+      expect(sanitized).not.toContain('coredns');
+      expect(sanitized).not.toContain('db-credentials');
+      expect(sanitized).not.toContain('app.example.com');
+    }
+  });
+});
+
+describe('sanitizeException', () => {
+  it('keeps the error name', () => {
+    const err = new TypeError('secret value was xyz');
+    const sanitized = sanitizeException(err);
+    expect(sanitized.name).toBe('TypeError');
+  });
+
+  it('redacts the error message', () => {
+    const err = new Error('Failed to connect to https://api.my-cluster.com:6443');
+    const sanitized = sanitizeException(err);
+    expect(sanitized.message).toBe('[redacted]');
+    expect(sanitized.message).not.toContain('my-cluster');
+    expect(sanitized.message).not.toContain('6443');
+  });
+
+  it('does not include the original stack trace', () => {
+    const err = new Error('subscription 12345-abcde not found');
+    err.stack = `Error: subscription 12345-abcde not found\n    at Object.<anonymous> (/app/src/utils.ts:42:11)`;
+    const sanitized = sanitizeException(err);
+    expect(sanitized.stack || '').not.toContain('12345-abcde');
+  });
+
+  it('handles errors with no message', () => {
+    const err = new Error();
+    const sanitized = sanitizeException(err);
+    expect(sanitized.name).toBe('Error');
+    expect(sanitized.message).toBe('[redacted]');
+  });
+});
