+  'backendtlspolicy',
+  'backendtrafficpolicy',
+  // Storage
+  'storage',
+  'persistentvolumes',
+  'persistentvolumeclaims',
+  'storageclasses',
+  'volumeattachments',
+  'csidrivers',
+  'csinodes',
+  // Config & secrets
+  'configmaps',
+  'secrets',
+  'resourcequotas',
+  'limitranges',
+  'leases',
+  // RBAC
+  'serviceaccounts',
+  'roles',
+  'rolebindings',
+  'clusterroles',
+  'clusterrolebindings',
+  // Cluster-level
+  'namespaces',
+  'nodes',
+  'events',
+  'horizontalpodautoscalers',
+  'poddisruptionbudgets',
+  'priorityclasses',
+  'runtimeclasses',
+  // Webhooks
+  'mutatingwebhookconfigurations',
+  'validatingwebhookconfigurations',
+  // CRDs
+  'customresources',
+  'crds',
+  // Navigation & auth
+  'settings',
+  'notifications',
+  'login',
+  'token',
+  'auth',
+  'plugins',
+  'create',
+  // AKS Desktop plugin routes
+  'azure',
+  'profile',
+  'projects',
+  'create-aks-project',
+  'import-aks-projects',
+  'create-namespace',
+  'add-cluster-aks',
+]);
+
+/**
+ * Sanitize a URL path by replacing dynamic segments (resource names, namespaces,
+ * cluster names) with generic placeholders to prevent leaking sensitive
+ * identifiers to Application Insights.
+ *
+ * @example
+ * sanitizeUrl('/c/my-cluster/pods/production/my-pod')
+ * // → '/c/{id}/pods/{id}/{id}'
+ *
+ * sanitizeUrl('/secrets/kube-system/my-secret')
+ * // → '/secrets/{id}/{id}'
+ *
+ * sanitizeUrl('https://host/c/cluster/deployments')
+ * // → '/c/{id}/deployments'
+ */
+export function sanitizeUrl(url: string): string {
+  try {
+    const urlObj = new URL(url, 'http://localhost');
+    const segments = urlObj.pathname.split('/').filter(Boolean);
+    const sanitized = segments.map(segment =>
+      KNOWN_ROUTE_SEGMENTS.has(segment.toLowerCase()) ? segment : '{id}'
+    );
+    // Return only the sanitized path — strip query params and hash
+    // which may also contain sensitive data.
+    return '/' + sanitized.join('/');
+  } catch {
+    return '/{sanitized}';
+  }
+}
+
+/**
+ * Create a sanitized copy of an Error that is safe to send to telemetry.
+ * Keeps the error name (e.g. "TypeError") and a generic message, but
+ * strips the original message which may contain resource names, API
+ * server URLs, or other sensitive information.
+ */
+export function sanitizeException(error: Error): Error {
+  const sanitized = new Error('[redacted]');
+  sanitized.name = error.name;
+  return sanitized;
+}
