+/**
+ * Known static path segments that are safe to include in telemetry.
+ * Any segment not in this set is treated as a potentially sensitive
+ * dynamic value (cluster name, namespace, resource name) and replaced
+ * with a placeholder.
+ */
+const KNOWN_ROUTE_SEGMENTS = new Set([
+  // Cluster prefix
+  'c',
+  // Workloads
+  'pods',
+  'deployments',
+  'daemonsets',
+  'statefulsets',
+  'replicasets',
+  'jobs',
+  'cronjobs',
+  // Network
